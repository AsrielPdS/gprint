{
  "compilerOptions": {
    "target": "esNext",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "module": "node16",
    "moduleResolution": "node16",
    "noImplicitThis": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "strict": false
  },
  "exclude": [
    "node_modules"
  ]
}